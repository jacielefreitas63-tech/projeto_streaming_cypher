// 1. CRIAR CONSTRAINTS (Regras de ID único)
CREATE CONSTRAINT user_id_unique IF NOT EXISTS FOR (u:User) REQUIRE u.id IS UNIQUE;
CREATE CONSTRAINT movie_id_unique IF NOT EXISTS FOR (m:Movie) REQUIRE m.id IS UNIQUE;
CREATE CONSTRAINT series_id_unique IF NOT EXISTS FOR (s:Series) REQUIRE s.id IS UNIQUE;

// 2. CRIAR GÊNEROS, ATORES E DIRETORES
CREATE (:Genre {name: 'Ficção Científica'}), (:Genre {name: 'Drama'}), (:Genre {name: 'Ação'}), (:Genre {name: 'Suspense'});
CREATE (:Actor {name: 'Keanu Reeves'}), (:Actor {name: 'Cillian Murphy'});
CREATE (:Director {name: 'Christopher Nolan'}), (:Director {name: 'Wachowskis'});

// 3. CRIAR 5 FILMES E 5 SÉRIES (Total 10 títulos)
CREATE (:Movie {id: 'M1', title: 'Matrix', ano: 1999}),
       (:Movie {id: 'M2', title: 'A Origem', ano: 2010}),
       (:Movie {id: 'M3', title: 'O Cavaleiro das Trevas', ano: 2008}),
       (:Movie {id: 'M4', title: 'Oppenheimer', ano: 2023}),
       (:Movie {id: 'M5', title: 'Interestelar', ano: 2014}),
       (:Series {id: 'S1', title: 'Dark', temporadas: 3}),
       (:Series {id: 'S2', title: 'Breaking Bad', temporadas: 5}),
       (:Series {id: 'S3', title: 'Stranger Things', temporadas: 4}),
       (:Series {id: 'S4', title: 'Black Mirror', temporadas: 5}),
       (:Series {id: 'S5', title: 'The Last of Us', temporadas: 1});

// 4. CRIAR 10 USUÁRIOS
UNWIND range(1, 10) AS i
CREATE (:User {id: 'U' + i, name: 'Usuário ' + i});

// 5. CRIAR RELACIONAMENTOS (Exemplos obrigatórios)
// Conectando usuários a filmes (com rating/avaliação)
MATCH (u:User {id: 'U1'}), (m:Movie {id: 'M1'}) CREATE (u)-[:WATCHED {rating: 5}]->(m);
MATCH (u:User {id: 'U2'}), (s:Series {id: 'S1'}) CREATE (u)-[:WATCHED {rating: 4}]->(s);
// Conectando atores e diretores
MATCH (a:Actor {name: 'Keanu Reeves'}), (m:Movie {id: 'M1'}) CREATE (a)-[:ACTED_IN]->(m);
MATCH (d:Director {name: 'Christopher Nolan'}), (m:Movie {id: 'M2'}) CREATE (d)-[:DIRECTED]->(m);
// Conectando ao gênero
MATCH (m:Movie {id: 'M1'}), (g:Genre {name: 'Ficção Científica'}) CREATE (m)-[:IN_GENRE]->(g);
